---
import DocsLayout from '../../../../layouts/DocsLayout.astro';
import CodeBlock from '../../../../components/CodeBlock.astro';
import PrerequisiteBadge from '../../../../components/PrerequisiteBadge.astro';
import FrameworkCallout from '../../../../components/FrameworkCallout.astro';
import ConfigFile from '../../../../components/ConfigFile.astro';
---

<DocsLayout
  title="Vite - Red Elements"
  description="How to use Red Elements web components in Vite projects"
>
  <div class="space-y-8">
    <!-- Breadcrumb -->
    <div class="flex items-center space-x-1 text-sm text-muted-foreground">
      <a href="/docs/introduction" class="hover:text-foreground transition-colors">Docs</a>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <a href="/docs/installation" class="hover:text-foreground transition-colors">Guides</a>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <span class="text-foreground font-medium">Vite</span>
    </div>

    <!-- Header -->
    <div>
      <h1 class="scroll-m-20 text-4xl font-extrabold tracking-tight lg:text-5xl">
        Using Red Elements with Vite
      </h1>
      <p class="text-lg text-muted-foreground mt-2">
        Integrate Red Elements web components into your Vite projects with any framework or vanilla JavaScript.
      </p>
    </div>

    <!-- Prerequisites -->
    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold tracking-tight">
        Prerequisites
      </h2>
      <div class="flex flex-wrap gap-2">
        <PrerequisiteBadge name="Node.js" version="18+" required />
        <PrerequisiteBadge name="Vite" version="4+" required />
      </div>
    </div>

    <!-- Installation -->
    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold tracking-tight">
        Installation
      </h2>
      <p class="leading-7">
        Install the Red Elements components you need using your preferred package manager:
      </p>

      <tabs-root default-value="npm" class="w-full">
        <tabs-list class="inline-flex h-10 items-center justify-center rounded-md bg-muted p-1 text-muted-foreground">
          <tab-trigger value="npm" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            npm
          </tab-trigger>
          <tab-trigger value="pnpm" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            pnpm
          </tab-trigger>
          <tab-trigger value="yarn" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            yarn
          </tab-trigger>
          <tab-trigger value="bun" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            bun
          </tab-trigger>
        </tabs-list>
        <tab-content value="npm" class="mt-4">
          <CodeBlock
            code="npm install @red-elements/dialog"
            lang="bash"
          />
        </tab-content>
        <tab-content value="pnpm" class="mt-4">
          <CodeBlock
            code="pnpm add @red-elements/dialog"
            lang="bash"
          />
        </tab-content>
        <tab-content value="yarn" class="mt-4">
          <CodeBlock
            code="yarn add @red-elements/dialog"
            lang="bash"
          />
        </tab-content>
        <tab-content value="bun" class="mt-4">
          <CodeBlock
            code="bun add @red-elements/dialog"
            lang="bash"
          />
        </tab-content>
      </tabs-root>
    </div>

    <!-- Configuration by Framework -->
    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold tracking-tight">
        Configuration
      </h2>
      <p class="leading-7">
        Choose your framework to see specific setup instructions:
      </p>

      <tabs-root default-value="vanilla" class="w-full">
        <tabs-list class="inline-flex h-10 items-center justify-center rounded-md bg-muted p-1 text-muted-foreground flex-wrap">
          <tab-trigger value="vanilla" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            Vanilla JS
          </tab-trigger>
          <tab-trigger value="react" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            React
          </tab-trigger>
          <tab-trigger value="vue" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            Vue
          </tab-trigger>
          <tab-trigger value="svelte" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            Svelte
          </tab-trigger>
        </tabs-list>

        <!-- Vanilla JS -->
        <tab-content value="vanilla" class="mt-4 space-y-4">
          <p class="leading-7">
            For vanilla JavaScript projects, import components directly in your entry file:
          </p>

          <ConfigFile
            filename="vite.config.ts"
            code={`import { defineConfig } from 'vite';

export default defineConfig({
  optimizeDeps: {
    include: ['@red-elements/dialog']
  }
});`}
            lang="typescript"
          />

          <ConfigFile
            filename="src/main.ts"
            code={`import '@red-elements/dialog';
import './style.css';

document.querySelector<HTMLDivElement>('#app')!.innerHTML = \`
  <div>
    <h1>Vite + Red Elements</h1>

    <dialog-root>
      <dialog-trigger as-child>
        <button type="button">Open Dialog</button>
      </dialog-trigger>

      <dialog class="rounded-lg p-6 max-w-md">
        <h2 data-dialog-title class="text-2xl font-bold mb-4">
          Welcome
        </h2>
        <p data-dialog-description class="mb-4">
          This is a dialog component.
        </p>
        <dialog-close as-child>
          <button type="button">Close</button>
        </dialog-close>
      </dialog>
    </dialog-root>
  </div>
\`;`}
            lang="typescript"
          />
        </tab-content>

        <!-- React -->
        <tab-content value="react" class="mt-4 space-y-4">
          <p class="leading-7">
            For React projects, use the React wrapper components:
          </p>

          <ConfigFile
            filename="vite.config.ts"
            code={`import { defineConfig } from 'vite';
import react from '@vitejs/plugin-react';

export default defineConfig({
  plugins: [react()],
  optimizeDeps: {
    include: ['@red-elements/dialog']
  }
});`}
            lang="typescript"
          />

          <ConfigFile
            filename="src/App.tsx"
            code={`import { DialogRoot, DialogTrigger, DialogClose } from '@red-elements/dialog';
import './App.css';

function App() {
  return (
    <div className="App">
      <h1>Vite + React + Red Elements</h1>

      <DialogRoot>
        <DialogTrigger asChild>
          <button type="button" className="btn-primary">
            Open Dialog
          </button>
        </DialogTrigger>

        <dialog className="rounded-lg p-6 max-w-md">
          <h2 data-dialog-title className="text-2xl font-bold mb-4">
            Welcome
          </h2>
          <p data-dialog-description className="mb-4">
            This is a dialog component.
          </p>
          <DialogClose asChild>
            <button type="button" className="btn-secondary">
              Close
            </button>
          </DialogClose>
        </dialog>
      </DialogRoot>
    </div>
  );
}

export default App;`}
            lang="tsx"
          />
        </tab-content>

        <!-- Vue -->
        <tab-content value="vue" class="mt-4 space-y-4">
          <p class="leading-7">
            For Vue projects, import and use web components directly:
          </p>

          <ConfigFile
            filename="vite.config.ts"
            code={`
            import { defineConfig } from 'vite';
            import vue from '@vitejs/plugin-vue';

            export default defineConfig({
              plugins: [
                vue({
                  template: {
                    compilerOptions: {
                      // Tell Vue to treat Red Elements as custom elements
                      isCustomElement: (tag) ${'='}> tag.startsWith('dialog-')
                    }
                  }
                })
              ],
              optimizeDeps: {
                include: ['@red-elements/dialog']
              }
            });
`}
            lang="typescript"
          />

          <ConfigFile
            filename="src/App.vue"
            code={`<script setup lang="ts">
import '@red-elements/dialog';
</script>

<template>
  <div>
    <h1>Vite + Vue + Red Elements</h1>

    <dialog-root>
      <dialog-trigger as-child>
        <button type="button" class="btn-primary">Open Dialog</button>
      </dialog-trigger>

      <dialog class="rounded-lg p-6 max-w-md">
        <h2 data-dialog-title class="text-2xl font-bold mb-4">
          Welcome
        </h2>
        <p data-dialog-description class="mb-4">
          This is a dialog component.
        </p>
        <dialog-close as-child>
          <button type="button" class="btn-secondary">Close</button>
        </dialog-close>
      </dialog>
    </dialog-root>
  </div>
</template>

<style scoped>
/* Your styles here */
</style>`}
            lang="vue"
          />
        </tab-content>

        <!-- Svelte -->
        <tab-content value="svelte" class="mt-4 space-y-4">
          <p class="leading-7">
            For Svelte projects, import components in your script tags:
          </p>

          <ConfigFile
            filename="vite.config.ts"
            code={`import { defineConfig } from 'vite';
import { svelte } from '@sveltejs/vite-plugin-svelte';

export default defineConfig({
  plugins: [svelte()],
  optimizeDeps: {
    include: ['@red-elements/dialog']
  }
});`}
            lang="typescript"
          />

          <ConfigFile
            filename="src/App.svelte"
            code={`<script lang="ts">
  import '@red-elements/dialog';
</script>

<main>
  <h1>Vite + Svelte + Red Elements</h1>

  <dialog-root>
    <dialog-trigger as-child>
      <button type="button" class="btn-primary">Open Dialog</button>
    </dialog-trigger>

    <dialog class="rounded-lg p-6 max-w-md">
      <h2 data-dialog-title class="text-2xl font-bold mb-4">
        Welcome
      </h2>
      <p data-dialog-description class="mb-4">
        This is a dialog component.
      </p>
      <dialog-close as-child>
        <button type="button" class="btn-secondary">Close</button>
      </dialog-close>
    </dialog>
  </dialog-root>
</main>

<style>
  /* Your styles here */
</style>`}
            lang="svelte"
          />
        </tab-content>
      </tabs-root>
    </div>

    <!-- TypeScript Support -->
    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold tracking-tight">
        TypeScript Support
      </h2>
      <p class="leading-7">
        Red Elements includes full TypeScript definitions. Add type references in your <code>tsconfig.json</code>:
      </p>

      <ConfigFile
        filename="tsconfig.json"
        code={`{
  "compilerOptions": {
    "types": ["vite/client", "@red-elements/dialog"]
  }
}`}
        lang="json"
      />
    </div>

    <!-- Common Patterns -->
    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold tracking-tight">
        Common Patterns
      </h2>

      <h3 class="scroll-m-20 text-xl font-semibold tracking-tight">
        Dynamic Imports
      </h3>
      <p class="leading-7">
        Load components only when needed for better performance:
      </p>

      <CodeBlock
        code={`// Only import when dialog is opened
document.getElementById('open-dialog')?.addEventListener('click', async () ${'='}> {
  await import('@red-elements/dialog');
  // Dialog is now available
});`}
        lang="typescript"
      />

      <h3 class="scroll-m-20 text-xl font-semibold tracking-tight mt-6">
        Environment Variables
      </h3>
      <p class="leading-7">
        Use Vite's environment variables with Red Elements:
      </p>

      <CodeBlock
        code={`
        // Use in component configuration
        comboboxRoot.addEventListener('combobox:search-change', async (e) => {
          const response = await fetch(apiUrl/search?q=+e.detail.search);
          // Handle response
        });
`}
        lang="typescript"
      />
    </div>

    <!-- Troubleshooting -->
    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold tracking-tight">
        Troubleshooting
      </h2>

      <h3 class="scroll-m-20 text-xl font-semibold tracking-tight">
        Components not defined
      </h3>
      <p class="leading-7">
        Make sure you've imported the components before using them in your templates/JSX. Components auto-register when imported.
      </p>

      <h3 class="scroll-m-20 text-xl font-semibold tracking-tight mt-6">
        Vue unknown custom element warning
      </h3>
      <p class="leading-7">
        Configure <code>isCustomElement</code> in your Vite config to tell Vue which tags are custom elements (see Vue configuration above).
      </p>

      <h3 class="scroll-m-20 text-xl font-semibold tracking-tight mt-6">
        HMR issues
      </h3>
      <p class="leading-7">
        If you experience Hot Module Replacement issues, add Red Elements packages to <code>optimizeDeps.include</code> in your Vite config.
      </p>
    </div>

    <!-- Next Steps -->
    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold tracking-tight">
        Next Steps
      </h2>
      <p class="leading-7">
        Explore the component documentation to learn about all available components:
      </p>
      <ul class="ml-6 list-disc space-y-2">
        <li class="leading-7">
          <a href="/docs/components/dialog" class="font-medium underline underline-offset-4">Dialog</a>
        </li>
        <li class="leading-7">
          <a href="/docs/components/combobox" class="font-medium underline underline-offset-4">Combobox</a>
        </li>
        <li class="leading-7">
          <a href="/docs/components/dropdown" class="font-medium underline underline-offset-4">Dropdown</a>
        </li>
        <li class="leading-7">
          <a href="/docs/components/accordion" class="font-medium underline underline-offset-4">Accordion</a>
        </li>
      </ul>
    </div>
  </div>
</DocsLayout>
