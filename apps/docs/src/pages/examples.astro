---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
---

<BaseLayout title="Examples - Red Elements">
  <div class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <section class="container py-8 max-w-screen-2xl px-4 md:px-8">
        <div class="mb-8">
          <h1 class="scroll-m-20 text-4xl font-bold tracking-tight mb-2">Live Examples</h1>
          <p class="text-lg text-muted-foreground">
            Interactive examples of Red Elements web components in action.
          </p>
        </div>

        <div class="space-y-12">
          <!-- Accordion Example -->
          <div class="space-y-4">
            <div>
              <h2 class="text-2xl font-bold mb-2">Accordion</h2>
              <p class="text-muted-foreground">
                A vertically stacked set of interactive headings
              </p>
            </div>
            <div class="rounded-lg border border-border p-6 max-w-2xl">
              <accordion-root class="w-full" collapsible>
                <accordion-item value="item-1" class="border-b border-border">
                  <accordion-header>
                    <accordion-trigger class="flex w-full items-center justify-between py-4 font-medium transition-all hover:underline cursor-pointer">
                      What are web components?
                      <svg class="h-4 w-4 shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                      </svg>
                    </accordion-trigger>
                  </accordion-header>
                  <accordion-content class="overflow-hidden text-sm">
                    <div class="pb-4 pt-0">
                      Web components are a set of web platform APIs that allow you to create custom, reusable, encapsulated HTML tags to use in web pages and web apps.
                    </div>
                  </accordion-content>
                </accordion-item>

                <accordion-item value="item-2" class="border-b border-border">
                  <accordion-header>
                    <accordion-trigger class="flex w-full items-center justify-between py-4 font-medium transition-all hover:underline cursor-pointer">
                      Are they framework agnostic?
                      <svg class="h-4 w-4 shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                      </svg>
                    </accordion-trigger>
                  </accordion-header>
                  <accordion-content class="overflow-hidden text-sm">
                    <div class="pb-4 pt-0">
                      Yes! Web components work with any framework (React, Vue, Angular, Svelte) or no framework at all. They're built on web standards.
                    </div>
                  </accordion-content>
                </accordion-item>

                <accordion-item value="item-3">
                  <accordion-header>
                    <accordion-trigger class="flex w-full items-center justify-between py-4 font-medium transition-all hover:underline cursor-pointer">
                      Can I style them?
                      <svg class="h-4 w-4 shrink-0 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                      </svg>
                    </accordion-trigger>
                  </accordion-header>
                  <accordion-content class="overflow-hidden text-sm">
                    <div class="pb-4 pt-0">
                      Absolutely! Red Elements are completely unstyled, giving you full control over their appearance using CSS, Tailwind, or any styling solution.
                    </div>
                  </accordion-content>
                </accordion-item>
              </accordion-root>
            </div>
          </div>

          <!-- Tooltip Example -->
          <div class="space-y-4">
            <div>
              <h2 class="text-2xl font-bold mb-2">Tooltip</h2>
              <p class="text-muted-foreground">
                A popup that displays information related to an element
              </p>
            </div>
            <div class="rounded-lg border border-border p-6 max-w-2xl">
              <div class="flex gap-4 flex-wrap">
                <tooltip-root>
                  <tooltip-trigger class="inline-flex items-center justify-center rounded-md text-sm font-medium h-10 px-4 border border-border hover:bg-accent cursor-pointer">
                    Hover me
                  </tooltip-trigger>
                  <tooltip-content class="z-50 overflow-hidden rounded-md bg-primary px-3 py-1.5 text-xs text-primary-foreground shadow-md">
                    This is a tooltip
                  </tooltip-content>
                </tooltip-root>

                <tooltip-root>
                  <tooltip-trigger class="inline-flex items-center justify-center rounded-md text-sm font-medium h-10 px-4 border border-border hover:bg-accent cursor-pointer">
                    Top
                  </tooltip-trigger>
                  <tooltip-content side="top" class="z-50 overflow-hidden rounded-md bg-primary px-3 py-1.5 text-xs text-primary-foreground shadow-md">
                    Tooltip on top
                  </tooltip-content>
                </tooltip-root>

                <tooltip-root>
                  <tooltip-trigger class="inline-flex items-center justify-center rounded-md text-sm font-medium h-10 px-4 border border-border hover:bg-accent cursor-pointer">
                    Right
                  </tooltip-trigger>
                  <tooltip-content side="right" class="z-50 overflow-hidden rounded-md bg-primary px-3 py-1.5 text-xs text-primary-foreground shadow-md">
                    Tooltip on right
                  </tooltip-content>
                </tooltip-root>

                <tooltip-root>
                  <tooltip-trigger class="inline-flex items-center justify-center rounded-md text-sm font-medium h-10 px-4 border border-border hover:bg-accent cursor-pointer">
                    Left
                  </tooltip-trigger>
                  <tooltip-content side="left" class="z-50 overflow-hidden rounded-md bg-primary px-3 py-1.5 text-xs text-primary-foreground shadow-md">
                    Tooltip on left
                  </tooltip-content>
                </tooltip-root>
              </div>
            </div>
          </div>

          <!-- Avatar Example -->
          <div class="space-y-4">
            <div>
              <h2 class="text-2xl font-bold mb-2">Avatar</h2>
              <p class="text-muted-foreground">
                An image element with a fallback for representing a user
              </p>
            </div>
            <div class="rounded-lg border border-border p-6 max-w-2xl">
              <div class="flex gap-4 items-center">
                <avatar-root class="relative flex h-10 w-10 shrink-0 overflow-hidden rounded-full">
                  <avatar-image src="https://github.com/thesambayo.png" alt="Samuel Adebayo" class="aspect-square h-full w-full" />
                  <avatar-fallback class="flex h-full w-full items-center justify-center rounded-full bg-muted">
                    SA
                  </avatar-fallback>
                </avatar-root>

                <avatar-root class="relative flex h-12 w-12 shrink-0 overflow-hidden rounded-full">
                  <avatar-image src="https://github.com/shadcn.png" alt="shadcn" class="aspect-square h-full w-full" />
                  <avatar-fallback class="flex h-full w-full items-center justify-center rounded-full bg-muted">
                    CN
                  </avatar-fallback>
                </avatar-root>

                <avatar-root class="relative flex h-14 w-14 shrink-0 overflow-hidden rounded-full">
                  <avatar-fallback class="flex h-full w-full items-center justify-center rounded-full bg-linear-to-br from-purple-500 to-pink-500 text-white font-semibold">
                    JD
                  </avatar-fallback>
                </avatar-root>
              </div>
            </div>
          </div>

          <!-- Dialog Example -->
          <div class="space-y-4">
            <div>
              <h2 class="text-2xl font-bold mb-2">Dialog</h2>
              <p class="text-muted-foreground">
                A modal dialog that interrupts the user
              </p>
            </div>
            <div class="rounded-lg border  p-6 max-w-2xl">
              <dialog-root>
                <dialog-trigger class="inline-flex items-center justify-center rounded-md text-sm font-medium h-10 px-4 bg-primary text-primary-foreground hover:opacity-90 cursor-pointer">
                  Open Dialog
                </dialog-trigger>
                <!-- <dialog class="backdrop:backdrop-blur-sm left-1/2 top-1/2 z-50 w-full max-w-lg -translate-x-1/2 -translate-y-1/2 gap-4 border border-border bg-background p-6 shadow-lg rounded-lg"> -->
                <dialog class="backdrop:backdrop-blur-xs  bg-background data-[state=open]:animate-in data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=open]:fade-in-0 data-[state=closed]:zoom-out-95 data-[state=open]:zoom-in-95 fixed top-[50%] left-[50%] z-50 w-full max-w-[calc(100%-2rem)] translate-x-[-50%] translate-y-[-50%] gap-4 rounded-lg border p-6 shadow-lg duration-200 sm:max-w-lg">
                  <div class="flex flex-col space-y-1.5 text-center sm:text-left">
                      <dialog-title class="text-lg font-semibold">
                        Edit Profile
                      </dialog-title>
                      <dialog-description class="text-sm text-muted-foreground">
                        Make changes to your profile here. Click save when you're done.
                      </dialog-description>
                    </div>
                    <div class="grid gap-4 py-4">
                      <div class="grid gap-2">
                        <label class="text-sm font-medium">Name</label>
                        <input type="text" placeholder="Enter your name" class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm" />
                      </div>
                      <div class="grid gap-2">
                        <label class="text-sm font-medium">Email</label>
                        <input type="email" placeholder="Enter your email" class="flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-2 text-sm" />
                      </div>
                    </div>
                    <div class="flex justify-end gap-2">
                      <dialog-close class="inline-flex items-center justify-center rounded-md text-sm font-medium h-10 px-4 border border-border hover:bg-accent cursor-pointer">
                        Cancel
                      </dialog-close>
                      <dialog-close class="inline-flex items-center justify-center rounded-md text-sm font-medium h-10 px-4 bg-primary text-primary-foreground hover:opacity-90 cursor-pointer">
                        Save Changes
                      </dialog-close>
                    </div>
                </dialog>
              </dialog-root>
            </div>
          </div>

          <!-- Tabs Example -->
          <div class="space-y-4">
            <div>
              <h2 class="text-2xl font-bold mb-2">Tabs</h2>
              <p class="text-muted-foreground">
                A set of layered sections of content
              </p>
            </div>
            <div class="rounded-lg border  p-6 max-w-2xl">
              <tabs-root default-value="account" class="w-full">
                <tabs-list class="inline-flex h-10 items-center justify-center rounded-md bg-muted p-1 text-muted-foreground">
                  <tab-trigger value="account" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
                    Account
                  </tab-trigger>
                  <tab-trigger value="password" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
                    Password
                  </tab-trigger>
                </tabs-list>
                <tab-content value="account" class="mt-4">
                  <div class="space-y-2">
                    <h3 class="font-medium">Account Settings</h3>
                    <p class="text-sm text-muted-foreground">
                      Make changes to your account here. Click save when you're done.
                    </p>
                  </div>
                </tab-content>
                <tab-content value="password" class="mt-4">
                  <div class="space-y-2">
                    <h3 class="font-medium">Password Settings</h3>
                    <p class="text-sm text-muted-foreground">
                      Change your password here. Make sure it's secure.
                    </p>
                  </div>
                </tab-content>
              </tabs-root>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  /* Accordion animations would go here if needed */
  accordion-trigger[data-state="open"] svg {
    transform: rotate(180deg);
  }
</style>
