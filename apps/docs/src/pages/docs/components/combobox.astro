            code={`combobox-root {
  position: relative;
  width: 300px;
}

combobox-trigger {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 12px;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  background: white;
  cursor: pointer;
}

combobox-trigger:hover {
  border-color: #9ca3af;
}

combobox-input {
  flex: 1;
  border: none;
  outline: none;
  font-size: 14px;
}

combobox-content {
  position: absolute;
  top: calc(100% + 4px);
  left: 0;
  right: 0;
  max-height: 300px;
  overflow-y: auto;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  background: white;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  z-index: 50;
}

combobox-item {
  display: block;
  padding: 8px 12px;
  cursor: pointer;
  font-size: 14px;
}

combobox-item[data-highlighted] {
  background-color: #f3f4f6;
}

combobox-item[data-selected] {
  background-color: #3b82f6;
  color: white;
}

combobox-empty {
  display: block;
  padding: 12px;
  text-align: center;
  color: #6b7280;
  font-size: 14px;
}`}
