{
  "name": "red-components",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "description": "Accessible unstyled web components",
  "author": "Samuel Adebayo <sambayo28@gmail.com>",
  "license": "MIT",
  "keywords": [
    "web components",
    "accessible",
    "unstyled",
    "customizable"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/thesambayo/red-components.git"
  },
  "homepage": "",
  "scripts": {
    "changeset": "changeset",
    "publish:packages": "changeset publish",
    "version:packages": "changeset version",
    "build": "rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript --silent",
    "story:dev": "storybook dev -p 6006 --no-open",
    "story:build": "storybook build",
    "showcase:dev": "pnpm build && pnpm --filter showcase dev",
    "showcase:build": "pnpm build && pnpm --filter showcase build",
    "showcase:lint": "pnpm --filter showcase lint",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm build && pnpm --filter docs build"
  },
  "dependencies": {
    "@changesets/cli": "^2.29.8",
    "@floating-ui/dom": "^1.7.4",
    "@lit-labs/signals": "^0.2.0",
    "@lit/context": "^1.1.6",
    "@lit/react": "^1.0.8",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@storybook/addon-links": "10.2.0",
    "@storybook/builder-vite": "10.2.0",
    "@storybook/web-components-vite": "10.2.0",
    "@types/node": "^22.19.7",
    "@types/react": "^19.2.9",
    "react": "^19.2.3",
    "rollup": "^4.56.0",
    "rollup-plugin-filesize": "^10.0.0",
    "storybook": "10.2.0",
    "typescript": "^5.9.3",
    "@storybook/addon-docs": "10.2.0"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  }
}
