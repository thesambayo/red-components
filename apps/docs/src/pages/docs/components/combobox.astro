        <tab-content value="php" class="mt-4">
          <CodeBlock
            code={`<!-- index.php -->
<!DOCTYPE html>
<html>
<head>
  <script type="module">
    import '@red-elements/combobox';
  </script>
</head>
<body>
  <combobox-root>
    <combobox-anchor>
      <combobox-trigger>
        <combobox-input placeholder="Search..." />
      </combobox-trigger>
    </combobox-anchor>
    <combobox-content>
      <?php foreach ($items as $item): ?>
        <combobox-item value="<?= $item['value'] ?>">
          <?= $item['label'] ?>
        </combobox-item>
      <?php endforeach; ?>
    </combobox-content>
  </combobox-root>
</body>
</html>`}
            lang="php"
          />
        </tab-content>

