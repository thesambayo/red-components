---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import CodeBlock from '../../../components/CodeBlock.astro';
---

<DocsLayout
  title="Combobox - Red Elements"
  description="An accessible combobox component with search and filtering capabilities."
>
  <div class="space-y-6">
    <div>
      <h1 class="scroll-m-20 text-4xl font-bold tracking-tight">Combobox</h1>
      <p class="text-lg text-[color:light-dark(var(--color-muted-foreground),var(--color-muted-foreground-dark))] mt-2">
        An accessible combobox component with search and filtering capabilities.
      </p>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-3xl font-semibold tracking-tight">
        Demo
      </h2>
      <div class="rounded-lg border border-[color:light-dark(var(--color-border),var(--color-border-dark))] p-6">
        <combobox-root class="w-full max-w-sm">
          <combobox-input
            placeholder="Search fruits..."
            class="w-full px-3 py-2 text-sm border border-[color:light-dark(var(--color-border),var(--color-border-dark))] rounded-md outline-none focus:border-[color:light-dark(var(--color-primary),var(--color-primary-dark))] focus:ring-2 focus:ring-[color:light-dark(#3b82f6,#3b82f6)]/10"
          ></combobox-input>
          <combobox-content class="min-w-[200px] max-h-[300px] bg-[color:light-dark(var(--color-background),var(--color-background-dark))] border border-[color:light-dark(var(--color-border),var(--color-border-dark))] rounded-lg shadow-lg p-1 overflow-y-auto">
            <combobox-item value="apple" class="block px-3 py-2 text-sm rounded cursor-pointer hover:bg-[color:light-dark(var(--color-accent),var(--color-accent-dark))] data-[highlighted]:bg-[color:light-dark(var(--color-accent),var(--color-accent-dark))] data-[selected]:bg-[color:light-dark(#dbeafe,#1e3a8a)] data-[selected]:text-[color:light-dark(#1e40af,#93c5fd)] outline-none">Apple</combobox-item>
            <combobox-item value="banana" class="block px-3 py-2 text-sm rounded cursor-pointer hover:bg-[color:light-dark(var(--color-accent),var(--color-accent-dark))] data-[highlighted]:bg-[color:light-dark(var(--color-accent),var(--color-accent-dark))] data-[selected]:bg-[color:light-dark(#dbeafe,#1e3a8a)] data-[selected]:text-[color:light-dark(#1e40af,#93c5fd)] outline-none">Banana</combobox-item>
            <combobox-item value="cherry" class="block px-3 py-2 text-sm rounded cursor-pointer hover:bg-[color:light-dark(var(--color-accent),var(--color-accent-dark))] data-[highlighted]:bg-[color:light-dark(var(--color-accent),var(--color-accent-dark))] data-[selected]:bg-[color:light-dark(#dbeafe,#1e3a8a)] data-[selected]:text-[color:light-dark(#1e40af,#93c5fd)] outline-none">Cherry</combobox-item>
            <combobox-item value="grape" class="block px-3 py-2 text-sm rounded cursor-pointer hover:bg-[color:light-dark(var(--color-accent),var(--color-accent-dark))] data-[highlighted]:bg-[color:light-dark(var(--color-accent),var(--color-accent-dark))] data-[selected]:bg-[color:light-dark(#dbeafe,#1e3a8a)] data-[selected]:text-[color:light-dark(#1e40af,#93c5fd)] outline-none">Grape</combobox-item>
            <combobox-item value="orange" class="block px-3 py-2 text-sm rounded cursor-pointer hover:bg-[color:light-dark(var(--color-accent),var(--color-accent-dark))] data-[highlighted]:bg-[color:light-dark(var(--color-accent),var(--color-accent-dark))] data-[selected]:bg-[color:light-dark(#dbeafe,#1e3a8a)] data-[selected]:text-[color:light-dark(#1e40af,#93c5fd)] outline-none">Orange</combobox-item>
            <combobox-empty class="block px-3 py-4 text-sm text-center text-[color:light-dark(var(--color-muted-foreground),var(--color-muted-foreground-dark))]">No fruits found</combobox-empty>
          </combobox-content>
        </combobox-root>
      </div>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-3xl font-semibold tracking-tight">
        Installation
      </h2>
      <tabs-root default-value="npm" class="w-full">
        <tabs-list class="inline-flex h-10 items-center justify-center rounded-md bg-[color:light-dark(var(--color-muted),var(--color-muted-dark))] p-1 text-[color:light-dark(var(--color-muted-foreground),var(--color-muted-foreground-dark))]">
          <tab-trigger value="npm" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-[color:light-dark(var(--color-background),var(--color-background-dark))] data-[state=active]:text-[color:light-dark(var(--color-foreground),var(--color-foreground-dark))] data-[state=active]:shadow-sm">
            npm
          </tab-trigger>
          <tab-trigger value="pnpm" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-[color:light-dark(var(--color-background),var(--color-background-dark))] data-[state=active]:text-[color:light-dark(var(--color-foreground),var(--color-foreground-dark))] data-[state=active]:shadow-sm">
            pnpm
          </tab-trigger>
          <tab-trigger value="yarn" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-[color:light-dark(var(--color-background),var(--color-background-dark))] data-[state=active]:text-[color:light-dark(var(--color-foreground),var(--color-foreground-dark))] data-[state=active]:shadow-sm">
            yarn
          </tab-trigger>
          <tab-trigger value="bun" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-[color:light-dark(var(--color-background),var(--color-background-dark))] data-[state=active]:text-[color:light-dark(var(--color-foreground),var(--color-foreground-dark))] data-[state=active]:shadow-sm">
            bun
          </tab-trigger>
        </tabs-list>
        <tab-content value="npm" class="mt-4">
          <CodeBlock
            code="npm install @red-elements/combobox"
            lang="bash"
          />
        </tab-content>
        <tab-content value="pnpm" class="mt-4">
          <CodeBlock
            code="pnpm add @red-elements/combobox"
            lang="bash"
          />
        </tab-content>
        <tab-content value="yarn" class="mt-4">
          <CodeBlock
            code="yarn add @red-elements/combobox"
            lang="bash"
          />
        </tab-content>
        <tab-content value="bun" class="mt-4">
          <CodeBlock
            code="bun add @red-elements/combobox"
            lang="bash"
          />
        </tab-content>
      </tabs-root>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-3xl font-semibold tracking-tight">
        Usage
      </h2>

      <tabs-root default-value="html" class="w-full">
        <tabs-list class="inline-flex h-10 items-center justify-center rounded-md bg-[color:light-dark(var(--color-muted),var(--color-muted-dark))] p-1 text-[color:light-dark(var(--color-muted-foreground),var(--color-muted-foreground-dark))]">
          <tab-trigger value="html" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-[color:light-dark(var(--color-background),var(--color-background-dark))] data-[state=active]:text-[color:light-dark(var(--color-foreground),var(--color-foreground-dark))] data-[state=active]:shadow-sm">
            HTML/JS
          </tab-trigger>
          <tab-trigger value="react" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-[color:light-dark(var(--color-background),var(--color-background-dark))] data-[state=active]:text-[color:light-dark(var(--color-foreground),var(--color-foreground-dark))] data-[state=active]:shadow-sm">
            React
          </tab-trigger>
          <tab-trigger value="vue" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-[color:light-dark(var(--color-background),var(--color-background-dark))] data-[state=active]:text-[color:light-dark(var(--color-foreground),var(--color-foreground-dark))] data-[state=active]:shadow-sm">
            Vue
          </tab-trigger>
          <tab-trigger value="svelte" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-[color:light-dark(var(--color-background),var(--color-background-dark))] data-[state=active]:text-[color:light-dark(var(--color-foreground),var(--color-foreground-dark))] data-[state=active]:shadow-sm">
            Svelte
          </tab-trigger>
          <tab-trigger value="angular" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-[color:light-dark(var(--color-background),var(--color-background-dark))] data-[state=active]:text-[color:light-dark(var(--color-foreground),var(--color-foreground-dark))] data-[state=active]:shadow-sm">
            Angular
          </tab-trigger>
        </tabs-list>
        <tab-content value="html" class="mt-4">
          <CodeBlock
            code={`import '@red-elements/combobox';

// Add to your HTML
document.body.innerHTML = \`
  <combobox-root>
    <combobox-anchor>
      <combobox-trigger>
        <combobox-input placeholder="Search..." />
      </combobox-trigger>
    </combobox-anchor>
    <combobox-content>
      <combobox-item value="apple">Apple</combobox-item>
      <combobox-item value="banana">Banana</combobox-item>
      <combobox-item value="orange">Orange</combobox-item>
      <combobox-empty>No results found</combobox-empty>
    </combobox-content>
  </combobox-root>
\`;

// Listen to events
const combobox = document.querySelector('combobox-root');
combobox.addEventListener('value-change', (e) => {
  console.log('Selected:', e.detail.value);
});`}
            lang="javascript"
          />
        </tab-content>

        <tab-content value="react" class="mt-4">
          <CodeBlock
            code={`import {
  ComboboxRoot,
  ComboboxAnchor,
  ComboboxTrigger,
  ComboboxInput,
  ComboboxContent,
  ComboboxItem,
  ComboboxEmpty
} from '@red-elements/combobox';

export function FruitCombobox() {
  const [value, setValue] = React.useState('');

  return (
    <ComboboxRoot onValueChange={(e) => setValue(e.detail.value)}>
      <ComboboxAnchor>
        <ComboboxTrigger>
          <ComboboxInput placeholder="Search fruits..." />
        </ComboboxTrigger>
      </ComboboxAnchor>
      <ComboboxContent>
        <ComboboxItem value="apple">Apple</ComboboxItem>
        <ComboboxItem value="banana">Banana</ComboboxItem>
        <ComboboxItem value="orange">Orange</ComboboxItem>
        <ComboboxEmpty>No results found</ComboboxEmpty>
      </ComboboxContent>
    </ComboboxRoot>
  );
}`}
            lang="tsx"
          />
        </tab-content>

        <tab-content value="vue" class="mt-4">
          <CodeBlock
            code={`<script setup>
import '@red-elements/combobox';
import { ref } from 'vue';

const value = ref('');

const handleValueChange = (e) => {
  value.value = e.detail.value;
};
</script>

<template>
  <combobox-root @value-change="handleValueChange">
    <combobox-anchor>
      <combobox-trigger>
        <combobox-input placeholder="Search fruits..." />
      </combobox-trigger>
    </combobox-anchor>
    <combobox-content>
      <combobox-item value="apple">Apple</combobox-item>
      <combobox-item value="banana">Banana</combobox-item>
      <combobox-item value="orange">Orange</combobox-item>
      <combobox-empty>No results found</combobox-empty>
    </combobox-content>
  </combobox-root>
</template>`}
            lang="vue"
          />
        </tab-content>

        <tab-content value="svelte" class="mt-4">
          <CodeBlock
            code={`<script>
  import '@red-elements/combobox';
  let value = '';

  function handleValueChange(e) {
    value = e.detail.value;
  }
</script>

<combobox-root on:value-change={handleValueChange}>
  <combobox-anchor>
    <combobox-trigger>
      <combobox-input placeholder="Search fruits..." />
    </combobox-trigger>
  </combobox-anchor>
  <combobox-content>
    <combobox-item value="apple">Apple</combobox-item>
    <combobox-item value="banana">Banana</combobox-item>
    <combobox-item value="orange">Orange</combobox-item>
    <combobox-empty>No results found</combobox-empty>
  </combobox-content>
</combobox-root>`}
            lang="svelte"
          />
        </tab-content>

        <tab-content value="angular" class="mt-4">
          <CodeBlock
            code={`// app.component.ts
import { Component } from '@angular/core';
import '@red-elements/combobox';

@Component({
  selector: 'app-root',
  template: \`
    <combobox-root (value-change)="onValueChange($event)">
      <combobox-anchor>
        <combobox-trigger>
          <combobox-input placeholder="Search fruits..."></combobox-input>
        </combobox-trigger>
      </combobox-anchor>
      <combobox-content>
        <combobox-item value="apple">Apple</combobox-item>
        <combobox-item value="banana">Banana</combobox-item>
        <combobox-item value="orange">Orange</combobox-item>
        <combobox-empty>No results found</combobox-empty>
      </combobox-content>
    </combobox-root>
  \`
})
export class AppComponent {
  onValueChange(event: any) {
    console.log('Selected:', event.detail.value);
  }
}`}
            lang="typescript"
          />
        </tab-content>
      </tabs-root>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-3xl font-semibold tracking-tight">
        Server-Side Usage
      </h2>
      <p class="leading-7">
        Red Elements work great with server-side frameworks. Here are examples:
      </p>

      <tabs-root default-value="nextjs" class="w-full">
        <tabs-list class="inline-flex h-10 items-center justify-center rounded-md bg-[color:light-dark(var(--color-muted),var(--color-muted-dark))] p-1 text-[color:light-dark(var(--color-muted-foreground),var(--color-muted-foreground-dark))]">
          <tab-trigger value="nextjs" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-[color:light-dark(var(--color-background),var(--color-background-dark))] data-[state=active]:text-[color:light-dark(var(--color-foreground),var(--color-foreground-dark))] data-[state=active]:shadow-sm">
