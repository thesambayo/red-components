---
const currentPath = Astro.url.pathname;

const components = [
  { name: 'Accordion', href: '/docs/components/accordion' },
  { name: 'Alert Dialog', href: '/docs/components/alert-dialog' },
  { name: 'Avatar', href: '/docs/components/avatar' },
  { name: 'Combobox', href: '/docs/components/combobox' },
  { name: 'Dialog', href: '/docs/components/dialog' },
  { name: 'Dropdown', href: '/docs/components/dropdown' },
  { name: 'Select', href: '/docs/components/select' },
  { name: 'Tabs', href: '/docs/components/tabs' },
  { name: 'Toast', href: '/docs/components/toast' },
  { name: 'Tooltip', href: '/docs/components/tooltip' },
];

const gettingStarted = [
  { name: 'Introduction', href: '/docs/introduction' },
  { name: 'Installation', href: '/docs/installation' },
];
---

<aside class="fixed top-14 z-30 hidden h-[calc(100vh-3.5rem)] w-full shrink-0 md:sticky md:block border-r border-[color:light-dark(var(--color-border),var(--color-border-dark))]">
  <div class="h-full py-6 pr-6 lg:py-8 overflow-y-auto">
    <nav class="space-y-6 text-sm">
      <div>
        <h4 class="mb-2 font-semibold text-[color:light-dark(var(--color-foreground),var(--color-foreground-dark))]">
          Getting Started
        </h4>
        <ul class="space-y-2 list-none p-0 m-0">
          {gettingStarted.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  "block py-1 px-2 rounded-md transition-colors no-underline",
                  currentPath === item.href
                    ? "bg-[color:light-dark(var(--color-accent),var(--color-accent-dark))] text-[color:light-dark(var(--color-foreground),var(--color-foreground-dark))] font-medium"
                    : "text-[color:light-dark(var(--color-muted-foreground),var(--color-muted-foreground-dark))] hover:text-[color:light-dark(var(--color-foreground),var(--color-foreground-dark))] hover:bg-[color:light-dark(var(--color-accent),var(--color-accent-dark))]"
                ]}
              >
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="mb-2 font-semibold text-[color:light-dark(var(--color-foreground),var(--color-foreground-dark))]">
          Components
        </h4>
        <ul class="space-y-2 list-none p-0 m-0">
          {components.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  "block py-1 px-2 rounded-md transition-colors no-underline",
                  currentPath === item.href
                    ? "bg-[color:light-dark(var(--color-accent),var(--color-accent-dark))] text-[color:light-dark(var(--color-foreground),var(--color-foreground-dark))] font-medium"
                    : "text-[color:light-dark(var(--color-muted-foreground),var(--color-muted-foreground-dark))] hover:text-[color:light-dark(var(--color-foreground),var(--color-foreground-dark))] hover:bg-[color:light-dark(var(--color-accent),var(--color-accent-dark))]"
                ]}
              >
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  </div>
</aside>
