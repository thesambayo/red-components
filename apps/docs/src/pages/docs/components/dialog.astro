---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import CodeBlock from '../../../components/CodeBlock.astro';
---

<DocsLayout
  title="Dialog - Red Elements"
  description="A modal dialog that interrupts the user with important content."
>
  <div class="space-y-8">
    <div>
      <h1 class="scroll-m-20 text-4xl font-extrabold lg:text-5xl tracking-tight">Dialog</h1>
      <p class="text-lg text-muted-foreground mt-2">
        A modal dialog that interrupts the user with important content and expects a response.
      </p>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold first:mt-0 tracking-tight">
        Demo
      </h2>
      <div class="relative rounded-xl border border-border bg-background shadow-sm p-6 md:p-8">
        <dialog-root>
          <dialog-trigger as-child>
            <button class="inline-flex items-center justify-center rounded-md text-sm font-medium h-10 px-4 bg-primary text-primary-foreground hover:opacity-90 cursor-pointer border-none">
              Open Dialog
            </button>
          </dialog-trigger>

          <dialog class="backdrop:backdrop-blur-sm left-1/2 top-1/2 z-50 w-full max-w-lg -translate-x-1/2 -translate-y-1/2 gap-4 border border-border bg-background p-6 shadow-lg rounded-lg">
            <h2 data-dialog-title class="text-lg font-semibold mb-2">Edit Profile</h2>
            <p data-dialog-description class="text-sm text-muted-foreground mb-4">
              Make changes to your profile here. Click save when you're done.
            </p>
            <div class="space-y-4 mb-6">
              <div class="space-y-2">
                <label class="text-sm font-medium">Name</label>
                <input type="text" placeholder="Enter your name" class="flex h-10 w-full rounded-md border border-border bg-transparent px-3 py-2 text-sm" />
              </div>
              <div class="space-y-2">
                <label class="text-sm font-medium">Email</label>
                <input type="email" placeholder="Enter your email" class="flex h-10 w-full rounded-md border border-border bg-transparent px-3 py-2 text-sm" />
              </div>
            </div>
            <div class="flex justify-end gap-2">
              <button data-dialog-close class="inline-flex items-center justify-center rounded-md text-sm font-medium h-10 px-4 border border-border hover:bg-accent cursor-pointer bg-transparent">
                Cancel
              </button>
              <button data-dialog-close class="inline-flex items-center justify-center rounded-md text-sm font-medium h-10 px-4 bg-primary text-primary-foreground hover:opacity-90 cursor-pointer border-none">
                Save Changes
              </button>
            </div>
          </dialog>
        </dialog-root>
      </div>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold first:mt-0 tracking-tight">
        Installation
      </h2>
      <tabs-root default-value="npm" class="w-full">
        <tabs-list class="inline-flex h-10 items-center justify-center rounded-md bg-muted p-1 text-muted-foreground">
          <tab-trigger value="npm" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            npm
          </tab-trigger>
          <tab-trigger value="pnpm" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            pnpm
          </tab-trigger>
          <tab-trigger value="yarn" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            yarn
          </tab-trigger>
          <tab-trigger value="bun" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            bun
          </tab-trigger>
        </tabs-list>
        <tab-content value="npm" class="mt-4">
          <CodeBlock code="npm install @red-elements/dialog" lang="bash" />
        </tab-content>
        <tab-content value="pnpm" class="mt-4">
          <CodeBlock code="pnpm add @red-elements/dialog" lang="bash" />
        </tab-content>
        <tab-content value="yarn" class="mt-4">
          <CodeBlock code="yarn add @red-elements/dialog" lang="bash" />
        </tab-content>
        <tab-content value="bun" class="mt-4">
          <CodeBlock code="bun add @red-elements/dialog" lang="bash" />
        </tab-content>
      </tabs-root>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold first:mt-0 tracking-tight">
        Usage
      </h2>

      <tabs-root default-value="html" class="w-full">
        <tabs-list class="inline-flex h-10 items-center justify-center rounded-md bg-muted p-1 text-muted-foreground">
          <tab-trigger value="html" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            HTML/JS
          </tab-trigger>
          <tab-trigger value="react" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            React
          </tab-trigger>
          <tab-trigger value="vue" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            Vue
          </tab-trigger>
        </tabs-list>
        <tab-content value="html" class="mt-4">
          <CodeBlock
            code={`import '@red-elements/dialog';

<dialog-root>
  <dialog-trigger as-child>
    <button>Open Dialog</button>
  </dialog-trigger>

  <dialog>
    <h2 data-dialog-title>Dialog Title</h2>
    <p data-dialog-description>
      Dialog description goes here.
    </p>
    <button data-dialog-close>Close</button>
  </dialog>
</dialog-root>`}
            lang="javascript"
          />
        </tab-content>
        <tab-content value="react" class="mt-4">
          <CodeBlock
            code={`import { DialogRoot, DialogTrigger } from '@red-elements/dialog';

export function MyDialog() {
  return (
    <DialogRoot>
      <DialogTrigger asChild>
        <button>Open Dialog</button>
      </DialogTrigger>

      <dialog>
        <h2 data-dialog-title>Dialog Title</h2>
        <p data-dialog-description>
          Dialog description goes here.
        </p>
        <button data-dialog-close>Close</button>
      </dialog>
    </DialogRoot>
  );
}`}
            lang="tsx"
          />
        </tab-content>
        <tab-content value="vue" class="mt-4">
          <CodeBlock
            code={`<script setup>
import '@red-elements/dialog';
</script>

<template>
  <dialog-root>
    <dialog-trigger as-child>
      <button>Open Dialog</button>
    </dialog-trigger>

    <dialog>
      <h2 data-dialog-title>Dialog Title</h2>
      <p data-dialog-description>
        Dialog description goes here.
      </p>
      <button data-dialog-close>Close</button>
    </dialog>
  </dialog-root>
</template>`}
            lang="vue"
          />
        </tab-content>
      </tabs-root>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold first:mt-0 tracking-tight">
        API Reference
      </h2>

      <div class="space-y-4">
        <h3 class="scroll-m-20 text-2xl font-semibold tracking-tight">
          DialogRoot
        </h3>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse border border-border">
            <thead>
              <tr class="bg-muted">
                <th class="border border-border px-4 py-2 text-left">Prop</th>
                <th class="border border-border px-4 py-2 text-left">Type</th>
                <th class="border border-border px-4 py-2 text-left">Default</th>
                <th class="border border-border px-4 py-2 text-left">Description</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="border border-border px-4 py-2"><code>open</code></td>
                <td class="border border-border px-4 py-2">boolean</td>
                <td class="border border-border px-4 py-2">-</td>
                <td class="border border-border px-4 py-2">Controlled open state</td>
              </tr>
              <tr>
                <td class="border border-border px-4 py-2"><code>default-open</code></td>
                <td class="border border-border px-4 py-2">boolean</td>
                <td class="border border-border px-4 py-2">false</td>
                <td class="border border-border px-4 py-2">Default open state (uncontrolled)</td>
              </tr>
              <tr>
                <td class="border border-border px-4 py-2"><code>modal</code></td>
                <td class="border border-border px-4 py-2">boolean</td>
                <td class="border border-border px-4 py-2">true</td>
                <td class="border border-border px-4 py-2">Whether dialog is modal (traps focus, has backdrop)</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3 class="scroll-m-20 text-2xl font-semibold tracking-tight mt-6">
          Data Attributes
        </h3>
        <ul class="ml-6 list-disc space-y-2">
          <li><code>data-dialog-title</code> - Marks the dialog title element</li>
          <li><code>data-dialog-description</code> - Marks the dialog description element</li>
          <li><code>data-dialog-close</code> - Marks elements that should close the dialog</li>
        </ul>
      </div>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold first:mt-0 tracking-tight">
        Accessibility
      </h2>
      <ul class="ml-6 list-disc space-y-2">
        <li class="leading-7">Uses native <code>&lt;dialog&gt;</code> element for built-in accessibility</li>
        <li class="leading-7">Focus is trapped within the modal when open</li>
        <li class="leading-7">ESC key closes the dialog</li>
        <li class="leading-7">Clicking the backdrop closes the dialog</li>
        <li class="leading-7">Proper ARIA labels for screen readers</li>
      </ul>
    </div>
  </div>
</DocsLayout>
