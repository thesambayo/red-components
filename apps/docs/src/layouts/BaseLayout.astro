---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Red Elements - Web Components Primitives',
  description = 'An open-source UI web component library for building unstyled, high-quality, accessible design systems and web apps.'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      const getThemePreference = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };
      const isDark = getThemePreference() === 'dark';
      document.documentElement.classList[isDark ? 'add' : 'remove']('dark');

      if (typeof localStorage !== 'undefined') {
        const observer = new MutationObserver(() => {
          const isDark = document.documentElement.classList.contains('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
      }
    </script>
  </head>
  <body>
    <slot />

    <!-- Load Red Elements Web Components -->
    <script type="module" src="/scripts/accordion.js"></script>
    <script type="module" src="/scripts/alert-dialog.js"></script>
    <script type="module" src="/scripts/avatar.js"></script>
    <script type="module" src="/scripts/combobox.js"></script>
    <script type="module" src="/scripts/dialog.js"></script>
    <script type="module" src="/scripts/dropdown.js"></script>
    <script type="module" src="/scripts/select.js"></script>
    <script type="module" src="/scripts/tabs.js"></script>
    <script type="module" src="/scripts/toast.js"></script>
    <script type="module" src="/scripts/tooltip.js"></script>
  </body>
</html>
