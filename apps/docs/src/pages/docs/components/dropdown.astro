---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import CodeBlock from '../../../components/CodeBlock.astro';
---

<DocsLayout
  title="Dropdown - Red Elements"
  description="A dropdown menu component with keyboard navigation and flexible positioning."
>
  <div class="space-y-8">
    <div>
      <h1 class="scroll-m-20 text-4xl font-extrabold lg:text-5xl tracking-tight">Dropdown</h1>
      <p class="text-lg text-muted-foreground mt-2">
        A dropdown menu component with keyboard navigation and flexible positioning.
      </p>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold first:mt-0 tracking-tight">
        Demo
      </h2>
      <div class="relative rounded-xl border border-border bg-background shadow-sm p-6 md:p-8">
        <dropdown-root>
          <dropdown-trigger class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium bg-background border border-border rounded-md cursor-pointer hover:bg-accent">
            Open Menu
            <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor">
              <path d="M2.5 4.5L6 8L9.5 4.5" stroke="currentColor" stroke-width="1.5" fill="none"/>
            </svg>
          </dropdown-trigger>
          <dropdown-content class="min-w-45 bg-background border border-border rounded-lg shadow-lg p-1">
            <dropdown-item value="edit" class="block px-3 py-2 text-sm rounded cursor-pointer hover:bg-accent outline-none">
              Edit
            </dropdown-item>
            <dropdown-item value="duplicate" class="block px-3 py-2 text-sm rounded cursor-pointer hover:bg-accent outline-none">
              Duplicate
            </dropdown-item>
            <dropdown-separator class="block h-px bg-border my-1"></dropdown-separator>
            <dropdown-item value="delete" class="block px-3 py-2 text-sm rounded cursor-pointer hover:bg-accent outline-none">
              Delete
            </dropdown-item>
          </dropdown-content>
        </dropdown-root>
      </div>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold first:mt-0 tracking-tight">
        Installation
      </h2>
      <tabs-root default-value="npm" class="w-full">
        <tabs-list class="inline-flex h-10 items-center justify-center rounded-md bg-muted p-1 text-muted-foreground">
          <tab-trigger value="npm" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            npm
          </tab-trigger>
          <tab-trigger value="pnpm" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            pnpm
          </tab-trigger>
          <tab-trigger value="yarn" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            yarn
          </tab-trigger>
          <tab-trigger value="bun" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            bun
          </tab-trigger>
        </tabs-list>
        <tab-content value="npm" class="mt-4">
          <CodeBlock
            code="npm install @red-elements/dropdown"
            lang="bash"
          />
        </tab-content>
        <tab-content value="pnpm" class="mt-4">
          <CodeBlock
            code="pnpm add @red-elements/dropdown"
            lang="bash"
          />
        </tab-content>
        <tab-content value="yarn" class="mt-4">
          <CodeBlock
            code="yarn add @red-elements/dropdown"
            lang="bash"
          />
        </tab-content>
        <tab-content value="bun" class="mt-4">
          <CodeBlock
            code="bun add @red-elements/dropdown"
            lang="bash"
          />
        </tab-content>
      </tabs-root>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold first:mt-0 tracking-tight">
        Usage
      </h2>

      <tabs-root default-value="html" class="w-full">
        <tabs-list class="inline-flex h-10 items-center justify-center rounded-md bg-muted p-1 text-muted-foreground">
          <tab-trigger value="html" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            HTML/JS
          </tab-trigger>
          <tab-trigger value="react" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            React
          </tab-trigger>
          <tab-trigger value="vue" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            Vue
          </tab-trigger>
          <tab-trigger value="svelte" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            Svelte
          </tab-trigger>
          <tab-trigger value="angular" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            Angular
          </tab-trigger>
        </tabs-list>
        <tab-content value="html" class="mt-4">
          <CodeBlock
            code={`import '@red-elements/dropdown';

// Use directly in your HTML
<dropdown-root>
  <dropdown-trigger>
    Open Menu
  </dropdown-trigger>
  <dropdown-content>
    <dropdown-item value="edit">Edit</dropdown-item>
    <dropdown-item value="duplicate">Duplicate</dropdown-item>
    <dropdown-separator></dropdown-separator>
    <dropdown-item value="delete">Delete</dropdown-item>
  </dropdown-content>
</dropdown-root>

// Listen to events
const dropdown = document.querySelector('dropdown-root');
dropdown.addEventListener('dropdown:item-select', (e) => {
  console.log('Selected:', e.detail.value);
});`}
            lang="javascript"
          />
        </tab-content>

        <tab-content value="react" class="mt-4">
          <CodeBlock
            code={`import {
  DropdownRoot,
  DropdownTrigger,
  DropdownContent,
  DropdownItem,
  DropdownSeparator
} from '@red-elements/dropdown';

export function DropdownDemo() {
  return (
    <DropdownRoot>
      <DropdownTrigger>Open Menu</DropdownTrigger>
      <DropdownContent>
        <DropdownItem value="edit">Edit</DropdownItem>
        <DropdownItem value="duplicate">Duplicate</DropdownItem>
        <DropdownSeparator />
        <DropdownItem value="delete">Delete</DropdownItem>
      </DropdownContent>
    </DropdownRoot>
  );
}`}
            lang="tsx"
          />
        </tab-content>

        <tab-content value="vue" class="mt-4">
          <CodeBlock
            code={`<script setup>
import '@red-elements/dropdown';
</script>

<template>
  <dropdown-root>
    <dropdown-trigger>Open Menu</dropdown-trigger>
    <dropdown-content>
      <dropdown-item value="edit">Edit</dropdown-item>
      <dropdown-item value="duplicate">Duplicate</dropdown-item>
      <dropdown-separator></dropdown-separator>
      <dropdown-item value="delete">Delete</dropdown-item>
    </dropdown-content>
  </dropdown-root>
</template>`}
            lang="vue"
          />
        </tab-content>

        <tab-content value="svelte" class="mt-4">
          <CodeBlock
            code={`<script>
  import '@red-elements/dropdown';
</script>

<dropdown-root>
  <dropdown-trigger>Open Menu</dropdown-trigger>
  <dropdown-content>
    <dropdown-item value="edit">Edit</dropdown-item>
    <dropdown-item value="duplicate">Duplicate</dropdown-item>
    <dropdown-separator></dropdown-separator>
    <dropdown-item value="delete">Delete</dropdown-item>
  </dropdown-content>
</dropdown-root>`}
            lang="svelte"
          />
        </tab-content>

        <tab-content value="angular" class="mt-4">
          <CodeBlock
            code={`// app.component.ts
import { Component } from '@angular/core';
import '@red-elements/dropdown';

@Component({
  selector: 'app-root',
  template: \`
    <dropdown-root>
      <dropdown-trigger>Open Menu</dropdown-trigger>
      <dropdown-content>
        <dropdown-item value="edit">Edit</dropdown-item>
        <dropdown-item value="duplicate">Duplicate</dropdown-item>
        <dropdown-separator></dropdown-separator>
        <dropdown-item value="delete">Delete</dropdown-item>
      </dropdown-content>
    </dropdown-root>
  \`
})
export class AppComponent {}`}
            lang="typescript"
          />
        </tab-content>
      </tabs-root>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold first:mt-0 tracking-tight">
        API Reference
      </h2>

      <div class="space-y-4">
        <h3 class="scroll-m-20 text-2xl font-semibold tracking-tight">
          DropdownRoot
        </h3>
        <p class="leading-7">
          The root component that manages dropdown state.
        </p>

        <h4 class="scroll-m-20 text-xl font-semibold tracking-tight mt-4">
          Events
        </h4>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse border border-border">
            <thead>
              <tr class="bg-muted">
                <th class="border border-border px-4 py-2 text-left">Event</th>
                <th class="border border-border px-4 py-2 text-left">Description</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="border border-border px-4 py-2"><code>dropdown:open</code></td>
                <td class="border border-border px-4 py-2">Emitted when the dropdown opens</td>
              </tr>
              <tr>
                <td class="border border-border px-4 py-2"><code>dropdown:close</code></td>
                <td class="border border-border px-4 py-2">Emitted when the dropdown closes</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="space-y-4">
        <h3 class="scroll-m-20 text-2xl font-semibold tracking-tight">
          DropdownContent
        </h3>
        <p class="leading-7">
          Container for dropdown items with positioning control.
        </p>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse border border-border">
            <thead>
              <tr class="bg-muted">
                <th class="border border-border px-4 py-2 text-left">Prop</th>
                <th class="border border-border px-4 py-2 text-left">Type</th>
                <th class="border border-border px-4 py-2 text-left">Default</th>
                <th class="border border-border px-4 py-2 text-left">Description</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="border border-border px-4 py-2"><code>side</code></td>
                <td class="border border-border px-4 py-2">"top" | "right" | "bottom" | "left"</td>
                <td class="border border-border px-4 py-2">"bottom"</td>
                <td class="border border-border px-4 py-2">Side of trigger to display content</td>
              </tr>
              <tr>
                <td class="border border-border px-4 py-2"><code>align</code></td>
                <td class="border border-border px-4 py-2">"start" | "center" | "end"</td>
                <td class="border border-border px-4 py-2">"start"</td>
                <td class="border border-border px-4 py-2">Alignment relative to trigger</td>
              </tr>
              <tr>
                <td class="border border-border px-4 py-2"><code>side-offset</code></td>
                <td class="border border-border px-4 py-2">number</td>
                <td class="border border-border px-4 py-2">4</td>
                <td class="border border-border px-4 py-2">Distance from trigger in pixels</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="space-y-4">
        <h3 class="scroll-m-20 text-2xl font-semibold tracking-tight">
          DropdownItem
        </h3>
        <p class="leading-7">
          Individual dropdown menu item.
        </p>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse border border-border">
            <thead>
              <tr class="bg-muted">
                <th class="border border-border px-4 py-2 text-left">Prop</th>
                <th class="border border-border px-4 py-2 text-left">Type</th>
                <th class="border border-border px-4 py-2 text-left">Description</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="border border-border px-4 py-2"><code>value</code></td>
                <td class="border border-border px-4 py-2">string</td>
                <td class="border border-border px-4 py-2">Unique identifier for the item</td>
              </tr>
              <tr>
                <td class="border border-border px-4 py-2"><code>disabled</code></td>
                <td class="border border-border px-4 py-2">boolean</td>
                <td class="border border-border px-4 py-2">Disable this item</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h4 class="scroll-m-20 text-xl font-semibold tracking-tight mt-4">
          Events
        </h4>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse border border-border">
            <thead>
              <tr class="bg-muted">
                <th class="border border-border px-4 py-2 text-left">Event</th>
                <th class="border border-border px-4 py-2 text-left">Detail</th>
                <th class="border border-border px-4 py-2 text-left">Description</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="border border-border px-4 py-2"><code>dropdown:item-select</code></td>
                <td class="border border-border px-4 py-2"><code>{'{ value: string }'}</code></td>
                <td class="border border-border px-4 py-2">Emitted when item is selected</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="space-y-4">
        <h3 class="scroll-m-20 text-2xl font-semibold tracking-tight">
          Other Components
        </h3>
        <ul class="ml-6 list-disc space-y-2">
          <li><code>DropdownTrigger</code> - Button that opens the dropdown</li>
          <li><code>DropdownLabel</code> - Label for grouping items</li>
          <li><code>DropdownSeparator</code> - Visual divider between items</li>
        </ul>
      </div>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold first:mt-0 tracking-tight">
        Accessibility
      </h2>
      <p class="leading-7">
        The dropdown component follows WAI-ARIA guidelines:
      </p>
      <ul class="ml-6 list-disc space-y-2">
        <li class="leading-7">Full keyboard navigation support</li>
        <li class="leading-7">Proper ARIA attributes for screen readers</li>
        <li class="leading-7">Focus management</li>
      </ul>
    </div>
  </div>
</DocsLayout>
