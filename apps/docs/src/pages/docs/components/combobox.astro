          </tab-trigger>
          <tab-trigger value="sveltekit" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-[color:light-dark(var(--color-background),var(--color-background-dark))] data-[state=active]:text-[color:light-dark(var(--color-foreground),var(--color-foreground-dark))] data-[state=active]:shadow-sm">
            SvelteKit
          </tab-trigger>
          <tab-trigger value="php" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-[color:light-dark(var(--color-background),var(--color-background-dark))] data-[state=active]:text-[color:light-dark(var(--color-foreground),var(--color-foreground-dark))] data-[state=active]:shadow-sm">
            PHP
          </tab-trigger>
          <tab-trigger value="rails" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-[color:light-dark(var(--color-background),var(--color-background-dark))] data-[state=active]:text-[color:light-dark(var(--color-foreground),var(--color-foreground-dark))] data-[state=active]:shadow-sm">
            Ruby/Rails
          </tab-trigger>
        </tabs-list>
        <tab-content value="nextjs" class="mt-4">
          <CodeBlock
            code={`// app/page.tsx (App Router)
'use client';

import {
  ComboboxRoot,
  ComboboxAnchor,
  ComboboxTrigger,
  ComboboxInput,
  ComboboxContent,
  ComboboxItem,
} from '@red-elements/combobox';

export default function Page() {
  return (
    <ComboboxRoot>
      <ComboboxAnchor>
        <ComboboxTrigger>
          <ComboboxInput placeholder="Search..." />
        </ComboboxTrigger>
      </ComboboxAnchor>
      <ComboboxContent>
        <ComboboxItem value="item1">Item 1</ComboboxItem>
        <ComboboxItem value="item2">Item 2</ComboboxItem>
      </ComboboxContent>
    </ComboboxRoot>
  );
}`}
