---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import CodeBlock from '../../../components/CodeBlock.astro';
---

<DocsLayout
  title="Select - Red Elements"
  description="A native web component select/dropdown with form integration, keyboard navigation, and accessibility support."
>
  <div class="space-y-8">
    <div>
      <h1 class="scroll-m-20 text-4xl font-extrabold lg:text-5xl tracking-tight">Select</h1>
      <p class="text-lg text-muted-foreground mt-2">
        A native web component select/dropdown with form integration, keyboard navigation, and accessibility support.
      </p>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold first:mt-0 tracking-tight">
        Demo
      </h2>
      <div class="relative rounded-xl border border-border bg-background shadow-sm p-6 md:p-8">
        <select-root name="country" default-value="us" class="w-full max-w-sm">
          <select-trigger class="flex items-center justify-between w-full px-3 py-2 text-sm border border-border rounded-md cursor-pointer hover:bg-accent data-[state=open]:border-primary">
            <select-value placeholder="Select country..."></select-value>
            <span>▼</span>
          </select-trigger>
          <select-content class="min-w-[200px] bg-background border border-border rounded-lg shadow-lg p-1">
            <select-item value="us" class="flex items-center px-3 py-2 text-sm rounded cursor-pointer hover:bg-accent data-[selected]:bg-[#dbeafe] data-[selected]:text-[#1e40af] outline-none">
              <select-item-indicator class="mr-2">✓</select-item-indicator>
              <select-item-text>United States</select-item-text>
            </select-item>
            <select-item value="uk" class="flex items-center px-3 py-2 text-sm rounded cursor-pointer hover:bg-accent data-[selected]:bg-[#dbeafe] data-[selected]:text-[#1e40af] outline-none">
              <select-item-indicator class="mr-2">✓</select-item-indicator>
              <select-item-text>United Kingdom</select-item-text>
            </select-item>
            <select-item value="ca" class="flex items-center px-3 py-2 text-sm rounded cursor-pointer hover:bg-accent data-[selected]:bg-[#dbeafe] data-[selected]:text-[#1e40af] outline-none">
              <select-item-indicator class="mr-2">✓</select-item-indicator>
              <select-item-text>Canada</select-item-text>
            </select-item>
          </select-content>
        </select-root>
      </div>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold first:mt-0 tracking-tight">
        Installation
      </h2>
      <tabs-root default-value="npm" class="w-full">
        <tabs-list class="inline-flex h-10 items-center justify-center rounded-md bg-muted p-1 text-muted-foreground">
          <tab-trigger value="npm" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            npm
          </tab-trigger>
          <tab-trigger value="pnpm" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            pnpm
          </tab-trigger>
          <tab-trigger value="yarn" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            yarn
          </tab-trigger>
          <tab-trigger value="bun" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            bun
          </tab-trigger>
        </tabs-list>
        <tab-content value="npm" class="mt-4">
          <CodeBlock
            code="npm install @red-elements/select"
            lang="bash"
          />
        </tab-content>
        <tab-content value="pnpm" class="mt-4">
          <CodeBlock
            code="pnpm add @red-elements/select"
            lang="bash"
          />
        </tab-content>
        <tab-content value="yarn" class="mt-4">
          <CodeBlock
            code="yarn add @red-elements/select"
            lang="bash"
          />
        </tab-content>
        <tab-content value="bun" class="mt-4">
          <CodeBlock
            code="bun add @red-elements/select"
            lang="bash"
          />
        </tab-content>
      </tabs-root>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold first:mt-0 tracking-tight">
        Usage
      </h2>

      <tabs-root default-value="html" class="w-full">
        <tabs-list class="inline-flex h-10 items-center justify-center rounded-md bg-muted p-1 text-muted-foreground">
          <tab-trigger value="html" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            HTML/JS
          </tab-trigger>
          <tab-trigger value="react" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            React
          </tab-trigger>
          <tab-trigger value="vue" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            Vue
          </tab-trigger>
          <tab-trigger value="svelte" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            Svelte
          </tab-trigger>
          <tab-trigger value="angular" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">
            Angular
          </tab-trigger>
        </tabs-list>
        <tab-content value="html" class="mt-4">
          <CodeBlock
            code={`import '@red-elements/select';

// Use directly in your HTML
<select-root name="country" default-value="us">
  <select-trigger>
    <select-value placeholder="Select country..."></select-value>
    <span>▼</span>
  </select-trigger>
  <select-content>
    <select-item value="us">
      <select-item-indicator>✓</select-item-indicator>
      <select-item-text>United States</select-item-text>
    </select-item>
    <select-item value="uk">
      <select-item-indicator>✓</select-item-indicator>
      <select-item-text>United Kingdom</select-item-text>
    </select-item>
    <select-item value="ca">
      <select-item-indicator>✓</select-item-indicator>
      <select-item-text>Canada</select-item-text>
    </select-item>
  </select-content>
</select-root>`}
            lang="javascript"
          />
        </tab-content>

        <tab-content value="react" class="mt-4">
          <CodeBlock
            code={`import {
  SelectRoot,
  SelectTrigger,
  SelectValue,
  SelectContent,
  SelectItem,
  SelectItemIndicator,
  SelectItemText
} from '@red-elements/select';

export function SelectDemo() {
  return (
    <SelectRoot name="country" defaultValue="us">
      <SelectTrigger>
        <SelectValue placeholder="Select country..." />
        <span>▼</span>
      </SelectTrigger>
      <SelectContent>
        <SelectItem value="us">
          <SelectItemIndicator>✓</SelectItemIndicator>
          <SelectItemText>United States</SelectItemText>
        </SelectItem>
        <SelectItem value="uk">
          <SelectItemIndicator>✓</SelectItemIndicator>
          <SelectItemText>United Kingdom</SelectItemText>
        </SelectItem>
        <SelectItem value="ca">
          <SelectItemIndicator>✓</SelectItemIndicator>
          <SelectItemText>Canada</SelectItemText>
        </SelectItem>
      </SelectContent>
    </SelectRoot>
  );
}`}
            lang="tsx"
          />
        </tab-content>

        <tab-content value="vue" class="mt-4">
          <CodeBlock
            code={`<script setup>
import '@red-elements/select';
</script>

<template>
  <select-root name="country" default-value="us">
    <select-trigger>
      <select-value placeholder="Select country..."></select-value>
      <span>▼</span>
    </select-trigger>
    <select-content>
      <select-item value="us">
        <select-item-indicator>✓</select-item-indicator>
        <select-item-text>United States</select-item-text>
      </select-item>
      <select-item value="uk">
        <select-item-indicator>✓</select-item-indicator>
        <select-item-text>United Kingdom</select-item-text>
      </select-item>
      <select-item value="ca">
        <select-item-indicator>✓</select-item-indicator>
        <select-item-text>Canada</select-item-text>
      </select-item>
    </select-content>
  </select-root>
</template>`}
            lang="vue"
          />
        </tab-content>

        <tab-content value="svelte" class="mt-4">
          <CodeBlock
            code={`<script>
  import '@red-elements/select';
</script>

<select-root name="country" default-value="us">
  <select-trigger>
    <select-value placeholder="Select country..."></select-value>
    <span>▼</span>
  </select-trigger>
  <select-content>
    <select-item value="us">
      <select-item-indicator>✓</select-item-indicator>
      <select-item-text>United States</select-item-text>
    </select-item>
    <select-item value="uk">
      <select-item-indicator>✓</select-item-indicator>
      <select-item-text>United Kingdom</select-item-text>
    </select-item>
    <select-item value="ca">
      <select-item-indicator>✓</select-item-indicator>
      <select-item-text>Canada</select-item-text>
    </select-item>
  </select-content>
</select-root>`}
            lang="svelte"
          />
        </tab-content>

        <tab-content value="angular" class="mt-4">
          <CodeBlock
            code={`// app.component.ts
import { Component } from '@angular/core';
import '@red-elements/select';

@Component({
  selector: 'app-root',
  template: \`
    <select-root name="country" default-value="us">
      <select-trigger>
        <select-value placeholder="Select country..."></select-value>
        <span>▼</span>
      </select-trigger>
      <select-content>
        <select-item value="us">
          <select-item-indicator>✓</select-item-indicator>
          <select-item-text>United States</select-item-text>
        </select-item>
        <select-item value="uk">
          <select-item-indicator>✓</select-item-indicator>
          <select-item-text>United Kingdom</select-item-text>
        </select-item>
        <select-item value="ca">
          <select-item-indicator>✓</select-item-indicator>
          <select-item-text>Canada</select-item-text>
        </select-item>
      </select-content>
    </select-root>
  \`
})
export class AppComponent {}`}
            lang="typescript"
          />
        </tab-content>
      </tabs-root>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold first:mt-0 tracking-tight">
        API Reference
      </h2>

      <div class="space-y-4">
        <h3 class="scroll-m-20 text-2xl font-semibold tracking-tight">
          SelectRoot
        </h3>
        <p class="leading-7">
          Main container that manages state and provides context.
        </p>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse border border-border">
            <thead>
              <tr class="bg-muted">
                <th class="border border-border px-4 py-2 text-left">Prop</th>
                <th class="border border-border px-4 py-2 text-left">Type</th>
                <th class="border border-border px-4 py-2 text-left">Description</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="border border-border px-4 py-2"><code>name</code></td>
                <td class="border border-border px-4 py-2">string</td>
                <td class="border border-border px-4 py-2">Form field name</td>
              </tr>
              <tr>
                <td class="border border-border px-4 py-2"><code>value</code></td>
                <td class="border border-border px-4 py-2">string</td>
                <td class="border border-border px-4 py-2">Controlled value</td>
              </tr>
              <tr>
                <td class="border border-border px-4 py-2"><code>default-value</code></td>
                <td class="border border-border px-4 py-2">string</td>
                <td class="border border-border px-4 py-2">Initial value for uncontrolled mode</td>
              </tr>
              <tr>
                <td class="border border-border px-4 py-2"><code>multiple</code></td>
                <td class="border border-border px-4 py-2">boolean</td>
                <td class="border border-border px-4 py-2">Enable multiple selection</td>
              </tr>
              <tr>
                <td class="border border-border px-4 py-2"><code>disabled</code></td>
                <td class="border border-border px-4 py-2">boolean</td>
                <td class="border border-border px-4 py-2">Disable the select</td>
              </tr>
              <tr>
                <td class="border border-border px-4 py-2"><code>required</code></td>
                <td class="border border-border px-4 py-2">boolean</td>
                <td class="border border-border px-4 py-2">Mark as required for forms</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h4 class="scroll-m-20 text-xl font-semibold tracking-tight mt-4">
          Events
        </h4>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse border border-border">
            <thead>
              <tr class="bg-muted">
                <th class="border border-border px-4 py-2 text-left">Event</th>
                <th class="border border-border px-4 py-2 text-left">Description</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="border border-border px-4 py-2"><code>select:value-change</code></td>
                <td class="border border-border px-4 py-2">Fires when value changes</td>
              </tr>
              <tr>
                <td class="border border-border px-4 py-2"><code>select:open-change</code></td>
                <td class="border border-border px-4 py-2">Fires when open state changes</td>
              </tr>
              <tr>
                <td class="border border-border px-4 py-2"><code>select:open</code></td>
                <td class="border border-border px-4 py-2">Fires when select opens</td>
              </tr>
              <tr>
                <td class="border border-border px-4 py-2"><code>select:close</code></td>
                <td class="border border-border px-4 py-2">Fires when select closes</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="space-y-4">
        <h3 class="scroll-m-20 text-2xl font-semibold tracking-tight">
          Other Components
        </h3>
        <ul class="ml-6 list-disc space-y-2">
          <li><code>SelectTrigger</code> - Button that opens/closes the dropdown</li>
          <li><code>SelectValue</code> - Displays the currently selected value(s)</li>
          <li><code>SelectContent</code> - Container for dropdown items</li>
          <li><code>SelectItem</code> - Individual selectable option</li>
          <li><code>SelectItemText</code> - Text content of the item</li>
          <li><code>SelectItemIndicator</code> - Visual indicator shown when item is selected</li>
          <li><code>SelectGroup</code> - Groups related items together</li>
          <li><code>SelectLabel</code> - Label for a group of items</li>
          <li><code>SelectSeparator</code> - Visual divider between groups</li>
        </ul>
      </div>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold first:mt-0 tracking-tight">
        Data Attributes
      </h2>
      <p class="leading-7">
        The following data attributes are automatically applied for styling:
      </p>
      <ul class="ml-6 list-disc space-y-2">
        <li><code>data-state="open|closed"</code> - Current open state on trigger</li>
        <li><code>data-disabled</code> - Present when disabled</li>
        <li><code>data-placeholder</code> - Present when no value selected</li>
        <li><code>data-selected</code> - Present on selected items</li>
        <li><code>data-highlighted</code> - Present when keyboard-highlighted</li>
        <li><code>data-state="checked|unchecked"</code> - Selection state on items</li>
      </ul>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold first:mt-0 tracking-tight">
        Keyboard Navigation
      </h2>
      <ul class="ml-6 list-disc space-y-2">
        <li><code>Space</code>, <code>Enter</code>, <code>ArrowDown</code>, <code>ArrowUp</code> - Open select (when closed)</li>
        <li><code>ArrowDown</code> - Navigate to next item</li>
        <li><code>ArrowUp</code> - Navigate to previous item</li>
        <li><code>Home</code> - Jump to first item</li>
        <li><code>End</code> - Jump to last item</li>
        <li><code>Enter</code>, <code>Space</code> - Select highlighted item</li>
        <li><code>Escape</code> - Close select</li>
        <li><code>Tab</code> - Close select and move focus</li>
      </ul>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold first:mt-0 tracking-tight">
        Accessibility
      </h2>
      <p class="leading-7">
        The select component implements full ARIA support:
      </p>
      <ul class="ml-6 list-disc space-y-2">
        <li class="leading-7">Full keyboard navigation support</li>
        <li class="leading-7">Proper ARIA attributes for screen readers</li>
        <li class="leading-7">Form integration using ElementInternals API</li>
        <li class="leading-7">Screen reader announcements</li>
      </ul>
    </div>
  </div>
</DocsLayout>
