---
import DocsLayout from '../../../../layouts/DocsLayout.astro';
import CodeBlock from '../../../../components/CodeBlock.astro';
import PrerequisiteBadge from '../../../../components/PrerequisiteBadge.astro';
import FrameworkCallout from '../../../../components/FrameworkCallout.astro';
import ConfigFile from '../../../../components/ConfigFile.astro';
---

<DocsLayout
  title="Nuxt 3 - Red Elements"
  description="How to use Red Elements web components in Nuxt 3 applications"
>
  <div class="space-y-8">
    <!-- Breadcrumb -->
    <div class="flex items-center space-x-1 text-sm text-muted-foreground">
      <a href="/docs/introduction" class="hover:text-foreground transition-colors">Docs</a>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <a href="/docs/installation" class="hover:text-foreground transition-colors">Guides</a>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <span class="text-foreground font-medium">Nuxt 3</span>
    </div>

    <!-- Header -->
    <div>
      <h1 class="scroll-m-20 text-4xl font-extrabold tracking-tight lg:text-5xl">
        Using Red Elements with Nuxt 3
      </h1>
      <p class="text-lg text-muted-foreground mt-2">
        Integrate Red Elements web components into your Nuxt 3 application with full SSR support.
      </p>
    </div>

    <!-- Prerequisites -->
    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold tracking-tight">
        Prerequisites
      </h2>
      <div class="flex flex-wrap gap-2">
        <PrerequisiteBadge name="Node.js" version="18+" required />
        <PrerequisiteBadge name="Nuxt" version="3+" required />
        <PrerequisiteBadge name="Vue" version="3+" required />
      </div>
    </div>

    <!-- Installation -->
    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold tracking-tight">
        Installation
      </h2>
      <p class="leading-7">
        Install the Red Elements components you need:
      </p>

      <tabs-root default-value="npm" class="w-full">
        <tabs-list class="inline-flex h-10 items-center justify-center rounded-md bg-muted p-1 text-muted-foreground">
          <tab-trigger value="npm" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">npm</tab-trigger>
          <tab-trigger value="pnpm" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">pnpm</tab-trigger>
          <tab-trigger value="yarn" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">yarn</tab-trigger>
        </tabs-list>
        <tab-content value="npm" class="mt-4"><CodeBlock code="npm install @red-elements/dialog" lang="bash" /></tab-content>
        <tab-content value="pnpm" class="mt-4"><CodeBlock code="pnpm add @red-elements/dialog" lang="bash" /></tab-content>
        <tab-content value="yarn" class="mt-4"><CodeBlock code="yarn add @red-elements/dialog" lang="bash" /></tab-content>
      </tabs-root>
    </div>

    <!-- Configuration -->
    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold tracking-tight">
        Configuration
      </h2>

      <FrameworkCallout type="important" title="Client-Side Components">
        Red Elements are client-side web components. Import them in client-only plugins or use the <code>.client.vue</code> suffix for components that use them.
      </FrameworkCallout>

      <h3 class="scroll-m-20 text-xl font-semibold tracking-tight">
        Configure Nuxt
      </h3>
      <p class="leading-7">
        Update your Nuxt configuration to recognize custom elements:
      </p>

      <ConfigFile
        filename="nuxt.config.ts"
        code={`export default defineNuxtConfig({
  vue: {
    compilerOptions: {
      isCustomElement: (tag) ${'='}> tag.includes('-')
    }
  },
  build: {
    transpile: ['@red-elements/dialog']
  }
});`}
        lang="typescript"
      />

      <h3 class="scroll-m-20 text-xl font-semibold tracking-tight mt-6">
        Create a Plugin
      </h3>
      <p class="leading-7">
        Create a client-side plugin to import Red Elements:
      </p>

      <ConfigFile
        filename="plugins/red-elements.client.ts"
        description="Client-only plugin"
        code={`export default defineNuxtPlugin(() ${'='}> {
  if (process.client) {
    import('@red-elements/dialog');
    import('@red-elements/dropdown');
    import('@red-elements/combobox');
  }
});`}
        lang="typescript"
      />
    </div>

    <!-- Usage -->
    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold tracking-tight">
        Usage
      </h2>
      <p class="leading-7">
        Use Red Elements in your components:
      </p>

      <ConfigFile
        filename="components/DialogDemo.client.vue"
        code={`<template>
  <div>
    <dialog-root>
      <dialog-trigger as-child>
        <button class="btn-primary">Open Dialog</button>
      </dialog-trigger>

      <dialog class="rounded-lg p-6 max-w-md">
        <h2 data-dialog-title class="text-2xl font-bold mb-4">
          Welcome
        </h2>
        <p data-dialog-description class="mb-4">
          This is a dialog component.
        </p>
        <dialog-close as-child>
          <button class="btn-secondary">Close</button>
        </dialog-close>
      </dialog>
    </dialog-root>
  </div>
</template>

<script setup lang="ts">
// Component logic here
</script>`}
        lang="vue"
      />
    </div>

    <!-- Common Patterns -->
    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold tracking-tight">
        Common Patterns
      </h2>

      <h3 class="scroll-m-20 text-xl font-semibold tracking-tight">
        Using with Nuxt Forms
      </h3>
      <CodeBlock
        code={`<template>
  <form @submit.prevent="handleSubmit">
    <combobox-root v-model="selectedValue">
      <combobox-input
        name="category"
        placeholder="Select category..."
        class="form-control"
      />
      <combobox-content>
        <combobox-item value="electronics">Electronics</combobox-item>
        <combobox-item value="books">Books</combobox-item>
      </combobox-content>
    </combobox-root>
    <button type="submit">Submit</button>
  </form>
</template>

<script setup lang="ts">
const selectedValue = ref('');

const handleSubmit = () ${'='}> {
  console.log('Selected:', selectedValue.value);
};
</script>`}
        lang="vue"
      />
    </div>

    <!-- Troubleshooting -->
    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold tracking-tight">
        Troubleshooting
      </h2>

      <h3 class="scroll-m-20 text-xl font-semibold tracking-tight">
        Hydration mismatch
      </h3>
      <p class="leading-7">
        Use <code>.client.vue</code> suffix for components using Red Elements to ensure they only render on the client.
      </p>

      <h3 class="scroll-m-20 text-xl font-semibold tracking-tight mt-6">
        Custom element warnings
      </h3>
      <p class="leading-7">
        Ensure <code>isCustomElement</code> is configured in <code>nuxt.config.ts</code> to prevent Vue warnings about unknown custom elements.
      </p>
    </div>

    <!-- Next Steps -->
    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold tracking-tight">
        Next Steps
      </h2>
      <ul class="ml-6 list-disc space-y-2">
        <li class="leading-7">
          <a href="/docs/components/dialog" class="font-medium underline underline-offset-4">Dialog</a>
        </li>
        <li class="leading-7">
          <a href="/docs/components/combobox" class="font-medium underline underline-offset-4">Combobox</a>
        </li>
        <li class="leading-7">
          <a href="/docs/components/dropdown" class="font-medium underline underline-offset-4">Dropdown</a>
        </li>
      </ul>
    </div>
  </div>
</DocsLayout>
