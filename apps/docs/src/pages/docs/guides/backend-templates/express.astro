---
import DocsLayout from '../../../../layouts/DocsLayout.astro';
import CodeBlock from '../../../../components/CodeBlock.astro';
import PrerequisiteBadge from '../../../../components/PrerequisiteBadge.astro';
import FrameworkCallout from '../../../../components/FrameworkCallout.astro';
import ConfigFile from '../../../../components/ConfigFile.astro';
---

<DocsLayout title="Express - Red Elements" description="How to use Red Elements web components with Express.js template engines">
  <div class="space-y-8">
    <div class="flex items-center space-x-1 text-sm text-muted-foreground">
      <a href="/docs/introduction" class="hover:text-foreground transition-colors">Docs</a>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <a href="/docs/installation" class="hover:text-foreground transition-colors">Guides</a>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <span class="text-foreground font-medium">Express</span>
    </div>

    <div>
      <h1 class="scroll-m-20 text-4xl font-extrabold tracking-tight lg:text-5xl">Using Red Elements with Express</h1>
      <p class="text-lg text-muted-foreground mt-2">Integrate Red Elements web components into your Express.js application with any template engine.</p>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold tracking-tight">Prerequisites</h2>
      <div class="flex flex-wrap gap-2">
        <PrerequisiteBadge name="Node.js" version="18+" required />
        <PrerequisiteBadge name="Express" version="4+" required />
      </div>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold tracking-tight">Installation</h2>

      <p class="leading-7">Using import maps with CDN (no npm install needed for Red Elements):</p>

      <ConfigFile
        filename="views/layout.ejs"
        code={`<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>

    <script type="importmap">
    {
      "imports": {
        "@red-elements/dialog": "https://cdn.jsdelivr.net/npm/@red-elements/dialog@latest/dist/dialog.js",
        "@red-elements/dropdown": "https://cdn.jsdelivr.net/npm/@red-elements/dropdown@latest/dist/dropdown.js"
      }
    }
    </script>
</head>
<body>
    <%- body %>

    <script type="module">
      import '@red-elements/dialog';
      import '@red-elements/dropdown';
    </script>
</body>
</html>`}
        lang="html"
      />
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold tracking-tight">Express Server Setup</h2>

      <ConfigFile
        filename="app.js"
        code={`const express = require('express');
const app = express();

app.set('view engine', 'ejs');
app.set('views', './views');

app.get('/', (req, res) ${'='}> {
  res.render('index', {
    title: 'Express + Red Elements',
    dialogTitle: 'Welcome',
    dialogContent: 'This is a Red Elements dialog!'
  });
});

app.listen(3000, () ${'='}> {
  console.log('Server running on http://localhost:3000');
});`}
        lang="javascript"
      />
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold tracking-tight">Usage in Templates</h2>

      <tabs-root default-value="ejs" class="w-full">
        <tabs-list class="inline-flex h-10 items-center justify-center rounded-md bg-muted p-1 text-muted-foreground">
          <tab-trigger value="ejs" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">EJS</tab-trigger>
          <tab-trigger value="pug" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">Pug</tab-trigger>
          <tab-trigger value="handlebars" class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-3 py-1.5 text-sm font-medium transition-all cursor-pointer data-[state=active]:bg-background data-[state=active]:text-foreground data-[state=active]:shadow-sm">Handlebars</tab-trigger>
        </tabs-list>

        <tab-content value="ejs" class="mt-4">
          <ConfigFile
            filename="views/index.ejs"
            code={`<h1>Express + Red Elements</h1>

<dialog-root>
  <dialog-trigger as-child>
    <button>Open Dialog</button>
  </dialog-trigger>

  <dialog class="rounded-lg p-6 max-w-md">
    <h2 data-dialog-title><%= dialogTitle %></h2>
    <p data-dialog-description><%= dialogContent %></p>
    <dialog-close as-child>
      <button>Close</button>
    </dialog-close>
  </dialog>
</dialog-root>`}
            lang="html"
          />
        </tab-content>

        <tab-content value="pug" class="mt-4">
          <ConfigFile
            filename="views/index.pug"
            code={`h1 Express + Red Elements

dialog-root
  dialog-trigger(as-child)
    button Open Dialog

  dialog.rounded-lg.p-6.max-w-md
    h2(data-dialog-title)= dialogTitle
    p(data-dialog-description)= dialogContent
    dialog-close(as-child)
      button Close`}
            lang="pug"
          />
        </tab-content>

        <tab-content value="handlebars" class="mt-4">
          <ConfigFile
            filename="views/index.hbs"
            code={`<h1>Express + Red Elements</h1>

<dialog-root>
  <dialog-trigger as-child>
    <button>Open Dialog</button>
  </dialog-trigger>

  <dialog class="rounded-lg p-6 max-w-md">
    <h2 data-dialog-title>{{dialogTitle}}</h2>
    <p data-dialog-description>{{dialogContent}}</p>
    <dialog-close as-child>
      <button>Close</button>
    </dialog-close>
  </dialog>
</dialog-root>`}
            lang="html"
          />
        </tab-content>
      </tabs-root>
    </div>

    <div class="space-y-4">
      <h2 class="scroll-m-20 border-b pb-2 text-2xl font-semibold tracking-tight">Next Steps</h2>
      <ul class="ml-6 list-disc space-y-2">
        <li class="leading-7"><a href="/docs/components/dialog" class="font-medium underline underline-offset-4">Dialog</a></li>
        <li class="leading-7"><a href="/docs/components/dropdown" class="font-medium underline underline-offset-4">Dropdown</a></li>
      </ul>
    </div>
  </div>
</DocsLayout>
